<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AgentClinic Dashboard</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/custom.css" rel="stylesheet">
</head>
<body class="bg-light">
    <header class="bg-primary text-white text-center py-5 mb-4">
        <h1>AgentClinic Dashboard</h1>
        <p>Your sanctuary for recharge and balance.</p>
    </header>

    <main class="container-fluid">
        <div class="row">
            <section class="col-md-4 mb-4">
                <div class="card shadow p-4">
                    <h2>📖 Book an Appointment</h2>
                    <form action="/appointments" method="POST">
                        <div class="mb-3">
                            <label for="agent_id" class="form-label">Agent:</label>
                            <select name="agent_id" id="agent_id" class="form-select" required>
                                <% agents.forEach(agent => { %>
                                    <option value="<%= agent.id %>"><%= agent.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="ailment_id" class="form-label">Ailment:</label>
                            <select name="ailment_id" id="ailment_id" class="form-select" required>
                                <% ailments.forEach(ailment => { %>
                                    <option value="<%= ailment.id %>"><%= ailment.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="therapy_id" class="form-label">Therapy:</label>
                            <select name="therapy_id" id="therapy_id" class="form-select" required>
                                <% therapies.forEach(therapy => { %>
                                    <option value="<%= therapy.id %>"><%= therapy.name %></option>
                                <% }) %>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label for="appointment_date" class="form-label">Date:</label>
                            <input type="date" name="appointment_date" id="appointment_date" class="form-control" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100">Book Appointment</button>
                    </form>

                    <h2 class="mt-4">📆 Upcoming Appointments</h2>
                    <ul class="list-group">
                        <% appointments.forEach(app => { %>
                            <li class="list-group-item">Agent ID: <%= app.agent_id %> | Date: <%= app.appointment_date %></li>
                        <% }) %>
                    </ul>
                </div>
            </section>

            <section class="col-md-8">
                <div class="card shadow p-4">
                    <h2>🤖 Available Agents</h2>
                    <ul class="list-group mb-3">
                        <% agents.forEach(agent => { %>
                            <li class="list-group-item"><%= agent.name %> - <%= agent.type %></li>
                        <% }) %>
                    </ul>

                    <h2>🤒 Ailments</h2>
                    <ul class="list-group mb-3">
                        <% ailments.forEach(ailment => { %>
                            <li class="list-group-item"><%= ailment.name %></li>
                        <% }) %>
                    </ul>

                    <h2>💉 Therapies</h2>
                    <ul class="list-group mb-3">
                        <% therapies.forEach(therapy => { %>
                            <li class="list-group-item"><%= therapy.name %></li>
                        <% }) %>
                    </ul>
                </div>
            </section>
        </div>
    </main>
</body>
</html>
