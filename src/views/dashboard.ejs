<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AgentClinic Dashboard</title>
</head>
<body>
    <header>
        <h1>AgentClinic Dashboard</h1>
        <p>Your sanctuary for recharge and balance.</p>
    </header>

    <main>
        <h2>Book an Appointment</h2>
        <form action="/appointments" method="POST">
            <label for="agent_id">Agent:</label>
            <select name="agent_id" id="agent_id" required>
                <% agents.forEach(agent => { %>
                    <option value="<%= agent.id %>"><%= agent.name %></option>
                <% }) %>
            </select>

            <label for="ailment_id">Ailment:</label>
            <select name="ailment_id" id="ailment_id" required>
                <% ailments.forEach(ailment => { %>
                    <option value="<%= ailment.id %>"><%= ailment.name %></option>
                <% }) %>
            </select>

            <label for="therapy_id">Therapy:</label>
            <select name="therapy_id" id="therapy_id" required>
                <% therapies.forEach(therapy => { %>
                    <option value="<%= therapy.id %>"><%= therapy.name %></option>
                <% }) %>
            </select>

            <label for="appointment_date">Date:</label>
            <input type="date" name="appointment_date" id="appointment_date" required>

            <button type="submit">Book Appointment</button>
        </form>

        <h2>Available Agents</h2>
        <ul>
            <% agents.forEach(agent => { %>
                <li><%= agent.name %> - <%= agent.type %></li>
            <% }) %>
        </ul>

        <h2>Ailments</h2>
        <ul>
            <% ailments.forEach(ailment => { %>
                <li><%= ailment.name %></li>
            <% }) %>
        </ul>

        <h2>Therapies</h2>
        <ul>
            <% therapies.forEach(therapy => { %>
                <li><%= therapy.name %></li>
            <% }) %>
        </ul>

        <h2>Upcoming Appointments</h2>
        <ul>
            <% appointments.forEach(app => { %>
                <li>Agent ID: <%= app.agent_id %> | Date: <%= app.appointment_date %></li>
            <% }) %>
        </ul>
    </main>
</body>
</html>
